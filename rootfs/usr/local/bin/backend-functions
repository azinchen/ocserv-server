#!/bin/sh
# shellcheck shell=sh

setcap_net_bind="${SETCAP_NET_BIND:-1}"
setcap_net_admin="${SETCAP_NET_ADMIN:-1}"
vpn_subnet="${VPN_SUBNET:-10.10.10.0/24}"
wan_if="${WAN_IF:-eth0}"
vpn_if="${VPN_IF:-vpns+}"
vpn_gateway="${VPN_GATEWAY:-}"
vpn_gateway6="${VPN_GATEWAY6:-}"
vpn_gateway_table="${VPN_GATEWAY_TABLE:-100}"
vpn_gateway_rule_prio="${VPN_GATEWAY_RULE_PRIO:-1000}"
ipv6_forward="${IPV6_FORWARD:-1}"
ipv6_nat="${IPV6_NAT:-0}"
ipv6_subnet="${IPV6_SUBNET:-fda9:4efe:7e3b:03ea::/64}"

# Logging functions
log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1"
}

log_error() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >&2
}
